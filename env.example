# =============================================================================
# The Million Dollar Crypto Page — Environment Variables
# =============================================================================
#
# Copy this file to `.env` for local development.
# For production (Vercel): Project Settings → Environment Variables.
#
# Production site: https://www.themilliondollarcryptopage.com
# =============================================================================


# -----------------------------------------------------------------------------
# FIREBASE (Client — Vite)
# -----------------------------------------------------------------------------
# Where: Firebase Console → Project Settings → General → Your apps → Web app
#        https://console.firebase.google.com/
#
# These are exposed to the browser (VITE_ prefix). Safe for client SDK use only.
# Do NOT put service account / private keys here.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=


# -----------------------------------------------------------------------------
# SITE URL
# -----------------------------------------------------------------------------
# Where: Your production domain (no trailing slash).
# Used by: server-side payment redirects, email context, DePay forward_to.

VITE_SITE_URL=https://www.themilliondollarcryptopage.com
SITE_URL=https://www.themilliondollarcryptopage.com


# ------------------------fffff-----------------------------------------------------
# DEPAY — Widget (Client)
# -----------------------------------------------------------------------------
# Where: DePay Dashboard → Integrations → New Integration → "Payment Widget"
#        https://app.depay.com/dev/integrations
#
# After creating the integration, copy the Integration ID shown in the embed code:
#   DePayWidgets.Payment({ integration: 'YOUR-INTEGRATION-ID' })
#
# Docs: https://depay.com/docs/payments/integrate/widget

VITE_DEPAY_INTEGRATION_ID=


# -----------------------------------------------------------------------------
# DEPAY — Server Integration
# -----------------------------------------------------------------------------
# Configure these in Vercel (server-only). Never expose private keys to the client.
#
# ── DePay Dashboard settings (https://app.depay.com/dev/integrations) ────────
#
# 1. Integration type:     Payment Widget
# 2. Dynamic configuration: ENABLED
#    Endpoint URL:
#      https://www.themilliondollarcryptopage.com/api/depay/configuration
#
# 3. Callback URL (successful payments):
#      https://www.themilliondollarcryptopage.com/api/depay/callback
#
# 4. Events URL (payment lifecycle: attempt, processing, succeeded, failed):
#      https://www.themilliondollarcryptopage.com/api/depay/events
#
# 5. Static redirect after payment (optional fallback):
#      https://www.themilliondollarcryptopage.com/buy
#
# 6. Restrict domains (add each separately):
#      www.themilliondollarcryptopage.com
#      themilliondollarcryptopage.com
#      localhost
#
# 7. Public key for dynamic configuration (YOUR key — upload to DePay):
#    Generate with:
#      openssl genpkey -algorithm RSA -out depay_signing_private.pem -pkeyopt rsa_keygen_bits:2048
#      openssl rsa -pubout -in depay_signing_private.pem -out depay_signing_public.pem
#    Paste contents of depay_signing_public.pem into DePay → Integration → Public Key
#
# 8. Public key from DePay (for verifying their callbacks) — paste below as DEPAY_PUBLIC_KEY.
#    Found in: DePay Dashboard → Integration → "Verify communication" section
#
# 9. Accepted tokens: configure in DePay Dashboard (USDT, USDC, ETH, etc.)
#    Set a receiver wallet address for each blockchain you accept.
#    The same address can be used as DEPAY_RECEIVER_WALLET below.
#
# Docs: https://depay.com/docs/payments/integrate/widget

# DePay's public key — verifies x-signature on callbacks/events FROM DePay to your server.
# Where: DePay Dashboard → your integration → "Verify communication"
DEPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAoG5FbALqQFwd3dsk3ptI\nReCdkqmyugg+A0wuGIKsf37Q6d66SoRT9QHjT9zQuKkXlnmMZZmm/LeatrnwIHRF\n510lRBEDErbZemm5q+yD3GN0cy9el7oVF7Egdv/P01NXZrNw+oMxdr6DFMDVVfFY\ndeh2v2bQSxaWjv4hqmB5+gNBcSiYrJTxSYGvbk4T14ldYWN4c3MWKWD05rkhjpGZ\nY1L/RsHBacKdq12LF1pdkYHEo0Ov7TwsMpgtb99K+W1n0t/2wlyW6AJyVwGBAyW7\ntcPfL6eMvXXk3aUFM8OGYFm2ndWimcgeZVNlUf6kMBm6RUN8FRu1pFjwoB4ZJMTN\nNQIDAQAB\n-----END PUBLIC KEY-----"

# YOUR RSA private key — signs dynamic configuration responses TO DePay.
# Where: Generated locally (see openssl commands above). Keep secret.
# Format: paste full PEM with \n for line breaks, or use Vercel multiline env var.
DEPAY_SIGNING_PRIVATE_KEY=

# Wallet address that receives crypto payments.
# Where: Your wallet (MetaMask, hardware wallet, etc.) — one address per chain in DePay,
#        or the same address if you use the default token list below.
DEPAY_RECEIVER_WALLET=

# Optional: override accepted tokens/receivers (JSON array).
# Where: Only needed if you want different receivers per chain outside DePay Dashboard defaults.
# If unset, defaults to USDT on Ethereum, Polygon, and BSC using DEPAY_RECEIVER_WALLET.
# DEPAY_ACCEPTED_TOKENS_JSON=[{"blockchain":"ethereum","token":"0xdac17f958d2ee523a2206206994597c13d831ec7","receiver":"0xYourWallet"},{"blockchain":"polygon","token":"0xc2132D05D31c914a87C6611C10748AEb04B58e8F","receiver":"0xYourWallet"},{"blockchain":"bsc","token":"0x55d398326f99059fF775485246999027B3197955","receiver":"0xYourWallet"}]


# -----------------------------------------------------------------------------
# RESEND (Email — Server)
# -----------------------------------------------------------------------------
# Where: Resend Dashboard → API Keys
#        https://resend.com/api-keys
#
# RESEND_FROM_EMAIL must be a verified sender/domain in Resend.
# Used when admin sends approval confirmation emails from /admin.

RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@themilliondollarcryptopage.com


# -----------------------------------------------------------------------------
# FIREBASE ADMIN (Server — DePay webhooks)
# -----------------------------------------------------------------------------
# Where: Firebase Console → Project Settings → Service accounts
#        → "Generate new private key" (downloads JSON file)
#
# Used by: /api/depay/callback and /api/depay/events to mark orders as paid in Firestore.
# Server-only. Never expose to the client.
#
# Option A (recommended on Vercel): paste the entire JSON file as one line.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
#
# Option B: individual fields from the same JSON file.

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
